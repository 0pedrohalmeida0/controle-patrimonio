# Backend (FastAPI) — copie para .env e preencha.
# Encontre esses valores em: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Origens permitidas no CORS (separadas por vírgula). Em dev, inclua
# http://localhost:5173 (Vite) e http://localhost:4173 (preview).
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Porta do uvicorn (default 8000)
PORT=8000
